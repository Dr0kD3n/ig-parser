{
  "name": "ig-bot",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm start --workspace=backend\" \"npm start --prefix ../ig-bot-backend\"",
    "locale": "concurrently \"npx cross-env VITE_AUTH_URL=http://localhost:5000 VITE_API_URL=http://localhost:5001 npm run locale --workspace=frontend\" \"npx cross-env PORT=5001 AUTH_SERVER_URL=http://localhost:5000 npm start --workspace=backend\" \"npm start --prefix ../ig-bot-backend\"",
    "dev:proxy": "set VITE_PROXY_BACKEND=true&& npm run dev --workspace=frontend",
    "dev:all": "concurrently \"npm run dev --workspace=frontend\" \"npm start --workspace=backend\" \"npm start --prefix ../ig-bot-backend\"",
    "test": "set NODE_ENV=test&& vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.2",
    "playwright": "^1.58.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "pkg": "^5.8.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  }
}
